# Decodo SERP Scraping API auth token.
# Get it from the Decodo dashboard: Web Scraping API → API Playground →
# top-right "Basic authentication token" field (already base64-encoded;
# sent as `Authorization: Basic <token>` on each request).
DECODO_AUTH=

# Optional alerting — leave blank to log alerts to stderr instead.
ALERT_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=

# Optional overrides.
RANK_DB=rank_tracker.db
LOG_LEVEL=INFO
